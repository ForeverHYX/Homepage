# Homepage environment variables
# Generate password hash with:
#   python -c "from passlib.context import CryptContext; c=CryptContext(schemes=['bcrypt']); print(c.hash('your-password'))"
HOMEPAGE_UPLOAD_USER=your-username
HOMEPAGE_UPLOAD_PASS_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HOMEPAGE_COOKIE_SECURE=true

# Daily remote data freshness (seconds). Current recommendations remain fresh
# every 15 minutes; the larger auxiliary payloads refresh less often.
HOMEPAGE_DAILY_REMOTE_CACHE_SECONDS=900
HOMEPAGE_DAILY_FEEDBACK_CONFIG_CACHE_SECONDS=3600
HOMEPAGE_DAILY_FAVORITES_CACHE_SECONDS=7200
