# Homepage environment variables
# Generate password hash with:
#   .venv/bin/python scripts/hash_password.py
HOMEPAGE_UPLOAD_USER=your-username
HOMEPAGE_UPLOAD_PASS_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HOMEPAGE_COOKIE_SECURE=true
HOMEPAGE_SESSION_TIMEOUT_SECONDS=86400
# HOMEPAGE_SESSION_FILE=/absolute/path/to/.sessions.json
# HOMEPAGE_SHARE_LINK_FILE=/absolute/path/to/.share-links.json
# HOMEPAGE_CONTENT_DIR=/absolute/path/to/content
# HOMEPAGE_UPLOAD_DIR=/absolute/path/to/uploads
# Keep false for direct local development; production Nginx sets this true.
HOMEPAGE_USE_X_ACCEL_REDIRECT=false
# Production disables the interactive FastAPI docs surface.
HOMEPAGE_ENABLE_API_DOCS=true

# Daily remote data freshness (seconds). Current recommendations remain fresh
# every 15 minutes; the larger auxiliary payloads refresh less often.
HOMEPAGE_DAILY_REMOTE_CACHE_SECONDS=900
HOMEPAGE_DAILY_FEEDBACK_CONFIG_CACHE_SECONDS=3600
HOMEPAGE_DAILY_FAVORITES_CACHE_SECONDS=7200
# HOMEPAGE_DAILY_RUN_READY_HOUR_UTC=4
# HOMEPAGE_DAILY_CACHE_FILE=/absolute/path/to/recommendations.json
# HOMEPAGE_DAILY_ARCHIVE_DIR=/absolute/path/to/archive

# Optional OpenAI-compatible endpoint for generated Daily article details.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
